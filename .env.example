# Gemini / Google AI (required for assess, regions, LLM transcription)
GOOGLE_API_KEY=your_api_key_here
# Optional: alternative env name used by some Colab setups
# gemini-api=your_api_key_here

# Model names (optional; defaults shown)
# AGENT_MODEL=gemini-2.0-flash
# VISION_MODEL=gemini-2.0-flash-preview-05-20

# Line detection: use Surya Layout as fallback when Detection returns no bboxes
# USE_LAYOUT_FALLBACK=true

# Surya detector tuning (see Surya README)
# DETECTOR_BATCH_SIZE=36
# DETECTOR_BLANK_THRESHOLD=0.3
# DETECTOR_TEXT_THRESHOLD=0.5
